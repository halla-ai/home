---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../i18n/ui';

const locale = 'ko';
---

<PageLayout
  title={t(locale, 'nav.contact')}
  description={t(locale, 'contact.description')}
  locale={locale}
>
  <div class="grid gap-12 lg:grid-cols-2">
    <!-- Contact Info -->
    <div>
      <h2 class="text-xl font-bold text-deep dark:text-white">연락처 정보</h2>
      <div class="mt-8 space-y-6">
        <div class="flex items-start gap-4">
          <div class="mt-0.5 w-10 h-10 rounded-xl bg-accent/10 dark:bg-accent/15 flex items-center justify-center shrink-0">
            <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-deep dark:text-slate-200">Email</p>
            <a href="mailto:yj.lee@chu.ac.kr" class="text-sm text-accent hover:text-accent-hover transition-colors">yj.lee@chu.ac.kr</a>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="mt-0.5 w-10 h-10 rounded-xl bg-accent/10 dark:bg-accent/15 flex items-center justify-center shrink-0">
            <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-deep dark:text-slate-200">전화</p>
            <p class="text-sm text-muted">064-741-7575</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="mt-0.5 w-10 h-10 rounded-xl bg-accent/10 dark:bg-accent/15 flex items-center justify-center shrink-0">
            <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-deep dark:text-slate-200">주소</p>
            <p class="text-sm text-muted leading-relaxed">(63092) 제주특별자치도 제주시 한라대학로 38</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="card p-8 lg:p-10">
      <h2 class="text-xl font-bold text-deep dark:text-white">{t(locale, 'contact.title')}</h2>
      <form class="mt-8 space-y-5" action="https://formspree.io/f/yj.lee@chu.ac.kr" method="POST">
        <div>
          <label for="name" class="block text-sm font-semibold text-deep dark:text-slate-200 mb-2">{t(locale, 'contact.name')}</label>
          <input type="text" id="name" name="name" required
            class="form-input" />
        </div>
        <div>
          <label for="email" class="block text-sm font-semibold text-deep dark:text-slate-200 mb-2">{t(locale, 'contact.email')}</label>
          <input type="email" id="email" name="_replyto" required
            class="form-input" />
        </div>
        <div>
          <label for="message" class="block text-sm font-semibold text-deep dark:text-slate-200 mb-2">{t(locale, 'contact.message')}</label>
          <textarea id="message" name="text" rows={6} required
            class="form-input resize-y"></textarea>
        </div>
        <button type="submit"
          class="btn-solid-gradient inline-flex items-center rounded-lg px-7 py-3.5 text-sm font-semibold text-white">
          {t(locale, 'contact.send')}
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</PageLayout>
