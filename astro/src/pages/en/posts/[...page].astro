---
import type { GetStaticPaths } from 'astro';
import PageLayout from '../../../layouts/PageLayout.astro';
import Card from '../../../components/ui/Card.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/ui';

const locale = 'en';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts');
  let posts = allPosts.filter((p) => p.id.startsWith('en/') && !p.data.draft);
  if (posts.length === 0) {
    posts = allPosts.filter((p) => p.id.startsWith('ko/') && !p.data.draft);
  }
  posts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return paginate(posts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function estimateReadTime(body: string): number {
  return Math.max(1, Math.ceil((body?.split(/\s+/).length || 0) / 200));
}
---

<PageLayout
  title={t(locale, 'nav.posts')}
  description="Latest news and activities from the Department of AI"
  locale={locale}
>
  <div class="grid gap-8 sm:grid-cols-2">
    {page.data.map((post) => {
      const slug = post.id.replace(/^(en|ko)\//, '');
      return (
        <Card
          href={`/en/posts/${slug}/`}
          variant="bento"
          class="group"
        >
          {post.data.image && (
            <div class="aspect-video overflow-hidden">
              <img
                src={post.data.image}
                alt={post.data.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-6">
            <div class="flex items-center gap-2 text-xs text-muted">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span class="text-border dark:text-white/20">&middot;</span>
              <span>{estimateReadTime(post.body ?? '')} {t(locale, 'common.min_read')}</span>
            </div>
            <h3 class="mt-3 text-lg font-bold text-deep dark:text-white group-hover:text-accent transition-colors duration-200 leading-snug">
              {post.data.title}
            </h3>
            {post.data.description && (
              <p class="mt-2 line-clamp-2 text-sm text-muted leading-relaxed">{post.data.description}</p>
            )}
            {post.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="rounded-full bg-accent/8 dark:bg-accent/12 px-2.5 py-0.5 text-xs font-medium text-deep dark:text-accent">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </Card>
      );
    })}
  </div>
  <Pagination page={page} locale={locale} />
</PageLayout>
