---
import PageLayout from '../../layouts/PageLayout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/ui';

const locale = 'en';
const allFaculty = await getCollection('faculty');
let faculty = allFaculty.filter((f) => f.id.startsWith(`${locale}/`));
if (faculty.length === 0) {
  faculty = allFaculty.filter((f) => f.id.startsWith('ko/'));
}
faculty = faculty.sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title={t(locale, 'nav.faculty')}
  description="Meet the faculty of the Department of AI"
  locale={locale}
>
  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {faculty.map((member) => (
      <Card variant="bento" class="group">
        <div class="h-1 bg-gradient-to-r from-accent to-cyan-400" aria-hidden="true"></div>
        <div class="p-7">
          <div class="flex items-start gap-5">
            <div class="h-20 w-20 flex-shrink-0 overflow-hidden rounded-2xl ring-2 ring-accent/10 dark:ring-accent/20">
              <img
                src={member.data.photo}
                alt={member.data.name_en || member.data.name}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="min-w-0">
              <h3 class="text-lg font-bold text-deep dark:text-white">{member.data.name_en || member.data.name}</h3>
              <p class="text-sm text-muted">{member.data.name}</p>
              {member.data.role && (
                <p class="text-sm font-semibold text-accent mt-0.5">{member.data.role}</p>
              )}
              <p class="text-sm text-muted mt-0.5">{member.data.title}</p>
            </div>
          </div>

          <div class="mt-6 pt-5 border-t border-border dark:border-white/[0.08] space-y-4">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-muted mb-2">Research Areas</p>
              <div class="flex flex-wrap gap-1.5">
                {member.data.research_areas.map((area: string) => (
                  <span class="rounded-full bg-accent-light dark:bg-accent/12 px-3 py-1 text-xs font-medium text-deep dark:text-accent">
                    {area}
                  </span>
                ))}
              </div>
            </div>

            <div>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-muted mb-1.5">Education</p>
              <ul class="space-y-0.5">
                {member.data.education.slice(0, 2).map((edu: string) => (
                  <li class="text-xs text-text dark:text-slate-300 leading-relaxed">{edu}</li>
                ))}
              </ul>
            </div>
          </div>

          <div class="mt-5 pt-4 border-t border-border dark:border-white/[0.08] flex flex-wrap gap-2.5">
            <a href={`mailto:${member.data.email}`} class="text-muted hover:text-accent transition-colors duration-200" title="Email">
              <svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </a>
            {member.data.website && (
              <a href={member.data.website} target="_blank" rel="noopener" class="text-muted hover:text-accent transition-colors duration-200" title="Website">
                <svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
                </svg>
              </a>
            )}
            {member.data.github && (
              <a href={member.data.github} target="_blank" rel="noopener" class="text-muted hover:text-accent transition-colors duration-200" title="GitHub">
                <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            )}
            {member.data.scholar && (
              <a href={member.data.scholar} target="_blank" rel="noopener" class="text-muted hover:text-accent transition-colors duration-200" title="Scholar">
                <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/>
                </svg>
              </a>
            )}
            {member.data.linkedin && (
              <a href={member.data.linkedin} target="_blank" rel="noopener" class="text-muted hover:text-accent transition-colors duration-200" title="LinkedIn">
                <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            )}
          </div>
        </div>
      </Card>
    ))}
  </div>
</PageLayout>
