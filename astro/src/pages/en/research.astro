---
import PageLayout from '../../layouts/PageLayout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/ui';

const locale = 'en';
const allProjects = await getCollection('projects');
let projects = allProjects.filter((p) => p.id.startsWith(`${locale}/`));
if (projects.length === 0) {
  projects = allProjects.filter((p) => p.id.startsWith('ko/'));
}
projects = projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout
  title={t(locale, 'nav.research')}
  description="Key research projects of the Department of AI"
  locale={locale}
>
  <div class="grid gap-8 md:grid-cols-2">
    {projects.map((project) => {
      const slug = project.id.replace(/^(en|ko)\//, '');
      return (
        <Card
          href={`/en/research/${slug}/`}
          variant="bento"
          class="group"
        >
          {project.data.image && (
            <div class="aspect-video overflow-hidden">
              <img
                src={project.data.image}
                alt={project.data.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-6">
            {project.data.subtitle && (
              <span class="inline-flex items-center rounded-full bg-accent/10 dark:bg-accent/15 px-3 py-1 text-xs font-semibold text-accent">
                {project.data.subtitle}
              </span>
            )}
            <h3 class="mt-3 text-xl font-bold text-deep dark:text-white group-hover:text-accent transition-colors duration-200 leading-snug">
              {project.data.title}
            </h3>
            <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-2">{project.data.summary}</p>
            {project.data.tools && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {(Array.isArray(project.data.tools) ? project.data.tools : project.data.tools.split(',').map((t: string) => t.trim())).map((tool: string) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 text-[11px] font-medium rounded-md bg-stone dark:bg-white/[0.06] text-muted dark:text-slate-400 border border-border/50 dark:border-white/10">
                    {tool}
                  </span>
                ))}
              </div>
            )}
          </div>
        </Card>
      );
    })}
  </div>
</PageLayout>
