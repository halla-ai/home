---
import { getCollection } from 'astro:content';
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/ui';
import SectionHeader from '../common/SectionHeader.astro';
import Card from '../ui/Card.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.id.startsWith(`${locale}/`))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<section class="py-24 md:py-32 bg-white dark:bg-abyss">
  <div class="container">
    <SectionHeader
      title={t(locale, 'sections.projects_title')}
      viewAllHref={locale === 'ko' ? '/research/' : '/en/research/'}
      viewAllLabel={t(locale, 'sections.view_all')}
    />

    <div class="mt-2 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project, i) => {
        const slug = project.id.replace(`${locale}/`, '');
        const href = locale === 'ko' ? `/research/${slug}/` : `/en/research/${slug}/`;
        return (
          <Card
            variant="bento"
            href={href}
            class={`group fade-up fade-up-d${i + 1}`}
          >
            {project.data.image && (
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6">
              {project.data.subtitle && (
                <span class="inline-block rounded-full bg-ember-light dark:bg-ember/10 px-3 py-1 text-xs font-semibold text-ember">
                  {project.data.subtitle}
                </span>
              )}
              <h3 class="mt-3 text-lg font-bold leading-snug text-deep dark:text-white group-hover:text-accent transition-colors duration-200">
                {project.data.title}
              </h3>
              <p class="mt-2 line-clamp-2 text-sm text-muted leading-relaxed">
                {project.data.summary}
              </p>
            </div>
          </Card>
        );
      })}
    </div>
  </div>
</section>
