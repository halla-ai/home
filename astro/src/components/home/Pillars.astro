---
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const prefix = locale === 'en' ? '/en' : '';

const pillars = [
  {
    title: t(locale, 'pillars.education_title'),
    description: t(locale, 'pillars.education_desc'),
    href: `${prefix}/curriculum/`,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />`,
    accent: '#0ea5e9',
    accentLight: 'rgba(14, 165, 233, 0.12)',
  },
  {
    title: t(locale, 'pillars.research_title'),
    description: t(locale, 'pillars.research_desc'),
    href: `${prefix}/research/`,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />`,
    accent: '#22d3ee',
    accentLight: 'rgba(34, 211, 238, 0.12)',
  },
  {
    title: t(locale, 'pillars.industry_title'),
    description: t(locale, 'pillars.industry_desc'),
    href: `${prefix}/career/`,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />`,
    accent: '#38bdf8',
    accentLight: 'rgba(56, 189, 248, 0.12)',
  },
];
---

<!-- Pillars: extends hero's dark canvas -->
<section class="pillar-section relative -mt-10 md:-mt-12 pt-16 md:pt-20 pb-24 md:pb-32">

  <div class="container relative z-10">
    <div class="grid md:grid-cols-3 gap-5 md:gap-6">
      {pillars.map((pillar, i) => (
        <a
          href={pillar.href}
          class={`group pillar-card fade-up fade-up-d${i + 1}`}
          style={`--pillar-accent: ${pillar.accent}; --pillar-accent-light: ${pillar.accentLight};`}
        >
          <!-- Glow orb -->
          <div class="pillar-card-glow" aria-hidden="true"></div>

          <div class="relative z-10 p-6 md:p-7">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5"
              style={`background: ${pillar.accentLight};`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5.5 h-5.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
                style={`color: ${pillar.accent};`}
                set:html={pillar.icon}
              />
            </div>
            <h3 class="text-lg font-bold text-white group-hover:text-[var(--pillar-accent)] transition-colors duration-200">
              {pillar.title}
            </h3>
            <p class="mt-2.5 text-sm text-slate-400 leading-relaxed">
              {pillar.description}
            </p>
            <span class="inline-flex items-center gap-1.5 mt-5 text-xs font-medium opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0"
              style={`color: ${pillar.accent};`}
            >
              {locale === 'ko' ? '자세히 보기' : 'Learn more'}
              <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .pillar-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      to bottom,
      var(--color-void) 0%,
      var(--color-void) 45%,
      var(--color-abyss) 65%,
      var(--color-deep) 85%,
      var(--color-deep) 100%
    );
  }

  :global(.dark) .pillar-section {
    background: var(--color-void);
  }

  /* Card */
  .pillar-card {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    transition:
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.4s ease,
      box-shadow 0.5s ease;
  }

  .pillar-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--pillar-accent) 40%, transparent);
    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.3),
      0 0 0 1px color-mix(in srgb, var(--pillar-accent) 20%, transparent);
  }

  /* Radial glow that follows card's accent */
  .pillar-card-glow {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 70%;
    height: 120%;
    background: radial-gradient(ellipse, var(--pillar-accent-light), transparent 70%);
    opacity: 0.5;
    transition: opacity 0.5s ease;
    z-index: 0;
  }

  .pillar-card:hover .pillar-card-glow {
    opacity: 1;
  }
</style>
