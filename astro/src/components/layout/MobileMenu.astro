---
import { t, getAlternateLocalePath, type Locale } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const prefix = locale === 'en' ? '/en' : '';

const primaryNavItems = [
  { key: 'about', href: `${prefix}/about/` },
  { key: 'faculty', href: `${prefix}/faculty/` },
  { key: 'curriculum', href: `${prefix}/curriculum/` },
  { key: 'research', href: `${prefix}/research/` },
  { key: 'posts', href: `${prefix}/posts/` },
  { key: 'career', href: `${prefix}/career/` },
  { key: 'admissions', href: `${prefix}/admissions/` },
];

const secondaryNavItems = [
  { key: 'tips', href: `${prefix}/tips/` },
  { key: 'contact', href: `${prefix}/contact/` },
  { key: 'location', href: `${prefix}/location/` },
];

const alternateLocale: Locale = locale === 'ko' ? 'en' : 'ko';
const alternatePath = getAlternateLocalePath(Astro.url, alternateLocale);
---

<!-- Overlay -->
<div
  id="mobile-overlay"
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Slide-out panel -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 h-full w-72 max-w-full bg-white dark:bg-abyss z-50 shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-border dark:border-white/[0.06]">
    <a href={locale === 'ko' ? '/' : '/en/'} class="flex items-center gap-2">
      <img
        src="/images/logo/logo-icon.svg"
        alt={locale === 'en' ? 'Cheju Halla University' : '제주한라대학교'}
        class="h-9 w-auto dark:hidden"
      />
      <img
        src="/images/logo/logo-icon-white.svg"
        alt={locale === 'en' ? 'Cheju Halla University' : '제주한라대학교'}
        class="h-9 w-auto hidden dark:block"
      />
      <div class="leading-tight pl-2">
        <p class="text-sm font-bold text-deep dark:text-white">{locale === 'en' ? 'Artificial Intelligence' : '인공지능학과'}</p>
        <p class="text-[10px] font-medium text-muted dark:text-slate-500 tracking-wide">{locale === 'en' ? 'Cheju Halla University' : '제주한라대학교'}</p>
      </div>
    </a>
    <button
      id="mobile-close"
      aria-label="Close menu"
      class="w-9 h-9 flex items-center justify-center rounded-lg text-muted hover:text-deep dark:hover:text-white hover:bg-surface dark:hover:bg-white/[0.05] transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto py-4 px-5" aria-label="Mobile navigation links">
    <ul class="space-y-0.5">
      {
        primaryNavItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="flex items-center px-3 py-2.5 rounded-lg text-text-navy dark:text-slate-300 font-medium hover:bg-accent-light dark:hover:bg-accent/10 hover:text-accent transition-colors duration-150"
            >
              {t(locale, `nav.${item.key}`)}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-4 pt-4 border-t border-border dark:border-white/[0.06]">
      <p class="px-3 mb-2 text-[11px] font-semibold text-muted uppercase tracking-wider">
        {locale === 'ko' ? '더보기' : 'More'}
      </p>
      <ul class="space-y-0.5">
        {
          secondaryNavItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="flex items-center px-3 py-2 rounded-lg text-sm text-muted hover:text-accent hover:bg-accent-light dark:hover:bg-accent/10 transition-colors duration-150"
              >
                {t(locale, `nav.${item.key}`)}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <!-- Footer: language toggle -->
  <div class="border-t border-border dark:border-white/[0.06] px-5 py-4 flex items-center justify-between">
    <a
      href={alternatePath}
      class="text-sm font-medium text-muted hover:text-accent transition-colors"
      lang={alternateLocale}
    >
      {alternateLocale === 'en' ? '영어로 보기 (EN)' : '한국어로 보기 (KO)'}
    </a>
    <div class="flex items-center gap-1 text-sm font-medium">
      <a
        href={locale === 'ko' ? Astro.url.pathname : getAlternateLocalePath(Astro.url, 'ko')}
        class={`px-2 py-1 rounded-l border transition-colors ${locale === 'ko' ? 'bg-accent text-white border-accent' : 'border-border dark:border-white/10 text-muted hover:text-deep dark:hover:text-white'}`}
        lang="ko"
      >KO</a>
      <a
        href={locale === 'en' ? Astro.url.pathname : getAlternateLocalePath(Astro.url, 'en')}
        class={`px-2 py-1 rounded-r border-t border-b border-r transition-colors ${locale === 'en' ? 'bg-accent text-white border-accent' : 'border-border dark:border-white/10 text-muted hover:text-deep dark:hover:text-white'}`}
        lang="en"
      >EN</a>
    </div>
  </div>
</div>

<script>
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');
  const openBtn = document.getElementById('mobile-open');
  const closeBtn = document.getElementById('mobile-close');

  function openMenu() {
    menu?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden', 'opacity-0');
    requestAnimationFrame(() => overlay?.classList.add('opacity-100'));
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('translate-x-full');
    overlay?.classList.remove('opacity-100');
    overlay?.classList.add('opacity-0');
    setTimeout(() => overlay?.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
